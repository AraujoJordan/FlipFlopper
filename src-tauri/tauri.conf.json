{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FlipFlopper",
  "version": "0.8.0",
  "identifier": "com.araujojordan.flipflopper",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "FlipFlopper",
        "width": 1440,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false,
        "visible": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/**/*", "**/*"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "license": "MIT",
    "licenseFile": "LICENSE"
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZBQjc5REJDOUIwQjg0OTMKUldTVGhBdWJ2SjIzYWhNOHdzYS8vTzAvRDZoaDg1Tk5xWkF2NEhhOW9pK2NEOCtMSG1FdmZIL1AK",
      "endpoints": [
        "https://github.com/AraujoJordan/FlipFlopper/releases/latest/download/latest.json"
      ]
    }
  }
}
